---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <div id="login-section" class="admin-login-card">
    <div class="login-icon">🔐</div>
    <h2>管理后台</h2>
    <p>请输入管理密码登录</p>
    <input type="password" id="admin-pwd" placeholder="输入密码后按回车" onkeydown="if(event.key==='Enter')doLogin()">
    <button onclick="doLogin()" class="btn-submit" style="border-radius:var(--radius-xs)">登录</button>
  </div>

  <div id="admin-section" class="admin-page" style="display:none">
    <div class="container">
      <div class="admin-card">
        <div class="admin-top">
          <h2>📦 订单管理</h2>
          <a href="/" class="btn-submit" style="padding:8px 20px;font-size:14px;border-radius:var(--radius-xs);text-decoration:none;display:inline-block">← 返回前台</a>
        </div>
        <div class="admin-stats" id="admin-stats">
          <div class="stat-card"><div class="stat-n" id="stat-total">0</div><div class="stat-l">全部订单</div></div>
          <div class="stat-card"><div class="stat-n" id="stat-pending">0</div><div class="stat-l">待处理</div></div>
          <div class="stat-card"><div class="stat-n" id="stat-today">¥0</div><div class="stat-l">今日收入</div></div>
        </div>
        <div class="admin-filters">
          <button class="filter-btn active" onclick="filterOrders('all')">全部</button>
          <button class="filter-btn" onclick="filterOrders('pending')">⏳ 待处理</button>
          <button class="filter-btn" onclick="filterOrders('preparing')">🍳 制作中</button>
          <button class="filter-btn" onclick="filterOrders('ready')">✅ 待取餐</button>
          <button class="filter-btn" onclick="filterOrders('completed')">📦 已完成</button>
          <button class="filter-btn" onclick="filterOrders('cancelled')">❌ 已取消</button>
        </div>
        <div id="orders-list"></div>
        <div id="no-orders" class="no-orders" style="display:none">
          <span class="no-icon">📭</span>
          <p>暂无订单</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  let adminToken = localStorage.getItem('admin_token') || '';
  let allOrders = [];
  let currentFilter = 'all';

  if (adminToken) loadOrders();

  async function doLogin() {
    const pwd = document.getElementById('admin-pwd').value;
    if (!pwd) return;
    adminToken = pwd;
    const ok = await loadOrders();
    if (!ok) { alert('密码错误'); adminToken = ''; localStorage.removeItem('admin_token'); }
  }

  async function loadOrders() {
    try {
      const resp = await fetch('/api/orders', { headers: { 'X-Admin-Token': adminToken } });
      if (!resp.ok) throw new Error('auth');
      allOrders = await resp.json();
      localStorage.setItem('admin_token', adminToken);
      document.getElementById('login-section').style.display = 'none';
      document.getElementById('admin-section').style.display = 'block';
      updateStats(); renderOrders(); return true;
    } catch(e) { return false; }
  }

  function updateStats() {
    const today = new Date().toDateString();
    const todayOrders = allOrders.filter(function(o){ return new Date(o.created_at).toDateString() === today; });
    document.getElementById('stat-total').textContent = allOrders.length;
    document.getElementById('stat-pending').textContent = allOrders.filter(function(o){ return o.status === 'pending'; }).length;
    document.getElementById('stat-today').textContent = '¥' + todayOrders.reduce(function(s,o){ return s + o.total_price; }, 0);
  }

  function filterOrders(status) {
    currentFilter = status;
    document.querySelectorAll('.filter-btn').forEach(function(b){ b.classList.remove('active'); });
    event.target.classList.add('active');
    renderOrders();
  }

  function renderOrders() {
    var filtered = currentFilter === 'all' ? allOrders : allOrders.filter(function(o){ return o.status === currentFilter; });
    var listEl = document.getElementById('orders-list');
    var noEl = document.getElementById('no-orders');
    if (filtered.length === 0) { listEl.innerHTML = ''; noEl.style.display = 'block'; return; }
    noEl.style.display = 'none';
    var sm = { pending:'⏳待处理', preparing:'🍳制作中', ready:'✅待取餐', completed:'📦已完成', cancelled:'❌已取消' };
    listEl.innerHTML = filtered.map(function(o) {
      var items = o.items || [];
      var itemsHtml = items.map(function(it){ return '<div class="order-dish"><span class="od-name">'+it.dish_name+' × '+it.quantity+'</span><span class="od-price">¥'+it.dish_price*it.quantity+'</span></div>'; }).join('');
      var notesHtml = o.notes ? '<div style="font-size:13px;color:#D4A017;margin-top:4px">💬 '+o.notes+'</div>' : '';
      var actions = '';
      if (o.status === 'pending') actions += '<button class="status-btn" onclick="updateStatus(\''+o.id+'\',\'preparing\')">🍳 开始制作</button>';
      if (o.status === 'preparing') actions += '<button class="status-btn" onclick="updateStatus(\''+o.id+'\',\'ready\')">✅ 制作完成</button>';
      if (o.status === 'ready') actions += '<button class="status-btn" onclick="updateStatus(\''+o.id+'\',\'completed\')">📦 已送达</button>';
      if (o.status === 'pending' || o.status === 'preparing') actions += '<button class="status-btn" onclick="updateStatus(\''+o.id+'\',\'cancelled\')" style="color:#EF4444">❌ 取消</button>';
      return '<div class="order-card '+o.status+'"><div class="order-top"><div><div class="order-id">#'+o.id+'</div><div class="order-customer">👤 '+o.customer_name+'</div><div class="order-address">📱 '+o.phone+'</div><div class="order-address">📍 '+o.address+'</div>'+notesHtml+'</div><div style="text-align:right"><span class="order-status os-'+o.status+'">'+(sm[o.status]||o.status)+'</span><div class="order-time" style="margin-top:4px">'+o.created_at+'</div></div></div><div class="order-dishes">'+itemsHtml+'</div><div class="order-bottom"><div class="order-total">¥'+o.total_price+'</div><div class="order-actions">'+actions+'</div></div></div>';
    }).join('');
  }

  async function updateStatus(orderId, status) {
    try {
      var resp = await fetch('/api/orders/'+orderId, { method:'PATCH', headers:{'Content-Type':'application/json','X-Admin-Token':adminToken}, body:JSON.stringify({status:status}) });
      if (!resp.ok) throw new Error();
      await loadOrders();
    } catch(e) { alert('更新失败'); }
  }

  setInterval(function(){ if (adminToken) loadOrders(); }, 15000);
</script>