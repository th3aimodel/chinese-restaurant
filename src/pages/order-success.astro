---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class=""success-page"">
    <div class=""success-icon"">🎉</div>
    <h1>下单成功！</h1>
    <p class=""success-sub"">您的订单已提交，我们会尽快为您备餐</p>
    <div class=""order-num"" id=""order-id""></div>
    <a href=""/menu"" class=""hero-btn"" style=""font-size:16px;padding:12px 32px"">继续点餐 →</a>
    <p class=""success-note"">🍳 商家接单后预计 30-45 分钟送达<br>如有疑问请联系客服</p>
  </section>
</BaseLayout>

<script is:inline>
  var params = new URLSearchParams(window.location.search);
  var orderId = params.get('id');
  if (orderId) {
    document.getElementById('order-id').textContent = '订单号：' + orderId;
  }
</script>