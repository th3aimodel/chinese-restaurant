---
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>中华美食 - 在线点餐</title>
  <meta name="description" content="正宗中餐外卖，粤菜湘菜川菜东北菜，在线点餐，快速送达">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/styles/global.css">
  <style>
    .cart-body::-webkit-scrollbar { width: 4px; }
    .cart-body::-webkit-scrollbar-track { background: transparent; }
    .cart-body::-webkit-scrollbar-thumb { background: var(--border-md); border-radius: 2px; }
    .cart-total { display:flex; justify-content:space-between; align-items:center; }
    .cart-total .label { font-size:16px; font-weight:600; }
    .cart-total .amount { font-size:28px; font-weight:800; color:var(--red); }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="header-inner">
      <a href="/" class="header-logo">
        <span class="logo-emoji">🥢</span>
        <span class="logo-text">中华美食</span>
      </a>
      <nav class="header-nav">
        <button class="menu-toggle" onclick="this.parentElement.classList.toggle('mobile-open')" aria-label="菜单">
          <span></span><span></span><span></span>
        </button>
        <div class="header-links">
          <a href="/">首页</a>
          <a href="/menu">菜单</a>
          <a href="/order-success">我的订单</a>
        </div>
        <button class="cart-btn" onclick="toggleCart()">
          🛒 <span class="cart-badge" id="cart-count">0</span>
        </button>
      </nav>
    </div>
  </header>

  <!-- Cart Sidebar -->
  <div class="cart-overlay" id="cart-overlay" onclick="toggleCart()"></div>
  <aside class="cart-sidebar" id="cart-sidebar">
    <div class="cart-header">
      <h2>🛒 购物车</h2>
      <button class="cart-close" onclick="toggleCart()">×</button>
    </div>
    <div class="cart-body" id="cart-body">
      <div class="cart-empty" id="cart-empty">
        <span class="empty-icon">🛒</span>
        <p>购物车是空的<br>快去点些好吃的吧</p>
      </div>
      <div id="cart-items"></div>
    </div>
    <div class="cart-footer" id="cart-footer" style="display:none">
      <div class="cart-total">
        <span class="label">合计</span>
        <span class="amount">¥<span id="cart-total">0</span></span>
      </div>
      <button class="btn-checkout" onclick="goCheckout()">去结算 →</button>
    </div>
  </aside>

  <!-- Main Content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-logo">🥢 中华美食</span>
      <p>正宗粤菜 · 地道湘菜 · 麻辣川菜 · 豪爽东北菜</p>
      <p class="footer-bottom">© 2025 中华美食 · 在线点餐系统 · 美味送到家</p>
    </div>
  </footer>

  <!-- Toast -->
  <div class="toast" id="toast"></div>

  <script is:inline>
    var cart = JSON.parse(localStorage.getItem('cart') || '[]');

    function saveCart() {
      localStorage.setItem('cart', JSON.stringify(cart));
      updateCartUI();
    }

    function updateCartUI() {
      var countEl = document.getElementById('cart-count');
      var bodyEl = document.getElementById('cart-items');
      var emptyEl = document.getElementById('cart-empty');
      var footerEl = document.getElementById('cart-footer');
      var totalEl = document.getElementById('cart-total');
      var totalItems = cart.reduce(function(s,i){ return s + i.quantity; }, 0);
      var totalPrice = cart.reduce(function(s,i){ return s + i.price * i.quantity; }, 0);
      countEl.textContent = totalItems;
      if (cart.length === 0) {
        emptyEl.style.display = 'block'; bodyEl.innerHTML = ''; footerEl.style.display = 'none';
      } else {
        emptyEl.style.display = 'none'; footerEl.style.display = 'block';
        totalEl.textContent = totalPrice.toFixed(0);
        bodyEl.innerHTML = cart.map(function(item, idx) {
          return '<div class="cart-item"><div class="cart-item-emoji">'+item.emoji+'</div><div class="cart-item-info"><h4>'+item.name+'</h4><div class="ci-price">¥'+item.price+' × '+item.quantity+'</div><div class="ci-subtotal">小计 ¥'+item.price*item.quantity+'</div></div><div class="qty-control"><button class="qty-btn" onclick="changeQty('+idx+',-1)">−</button><span class="qty-num">'+item.quantity+'</span><button class="qty-btn" onclick="changeQty('+idx+',1)">+</button></div></div>';
        }).join('');
      }
      document.querySelectorAll('.dish-card').forEach(function(card) {
        var dishId = card.dataset.dishId;
        var inCart = cart.find(function(i){ return i.id === dishId; });
        var addBtn = card.querySelector('.btn-add');
        var qtyCtrl = card.querySelector('.qty-control');
        var qtyNum = card ? card.querySelector('.qty-num') : null;
        if (addBtn && qtyCtrl) {
          if (inCart) { addBtn.style.display = 'none'; qtyCtrl.style.display = 'flex'; if(qtyNum) qtyNum.textContent = inCart.quantity; }
          else { addBtn.style.display = 'inline-block'; qtyCtrl.style.display = 'none'; }
        }
      });
    }

    function addToCart(id, name, price, emoji) {
      var existing = cart.find(function(i){ return i.id === id; });
      if (existing) existing.quantity++;
      else cart.push({id:id, name:name, price:price, emoji:emoji, quantity:1});
      saveCart();
      showToast(emoji + ' ' + name + ' 已加入购物车');
    }

    function changeQty(idx, delta) {
      cart[idx].quantity += delta;
      if (cart[idx].quantity <= 0) cart.splice(idx, 1);
      saveCart();
    }

    function toggleCart() {
      document.getElementById('cart-overlay').classList.toggle('open');
      document.getElementById('cart-sidebar').classList.toggle('open');
    }

    function goCheckout() {
      if (cart.length === 0) return;
      window.location.href = '/checkout';
    }

    function showToast(msg) {
      var el = document.getElementById('toast');
      el.textContent = msg;
      el.classList.add('show');
      setTimeout(function(){ el.classList.remove('show'); }, 2200);
    }

    updateCartUI();
  </script>
</body>
</html>