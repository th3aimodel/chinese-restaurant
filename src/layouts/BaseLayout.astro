---
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>中华美食 - 在线点餐</title>
  <meta name="description" content="正宗中餐外卖，粤菜湘菜川菜东北菜，在线点餐，快速送达">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="header-inner">
      <a href="/" class="header-logo">
        <span>🥢</span> 中华美食
      </a>
      <nav class="header-nav">
        <a href="/menu">菜单</a>
        <button class="cart-btn" onclick="toggleCart()">
          🛒 购物车 <span class="cart-badge" id="cart-count">0</span>
        </button>
      </nav>
    </div>
  </header>

  <!-- Cart Sidebar -->
  <div class="cart-overlay" id="cart-overlay" onclick="toggleCart()"></div>
  <aside class="cart-sidebar" id="cart-sidebar">
    <div class="cart-header">
      <h2>🛒 购物车</h2>
      <button class="cart-close" onclick="toggleCart()">&times;</button>
    </div>
    <div class="cart-body" id="cart-body">
      <div class="cart-empty" id="cart-empty">
        <span>🛒</span>
        <p>购物车是空的<br>快去点些好吃的吧</p>
      </div>
      <div id="cart-items"></div>
    </div>
    <div class="cart-footer" id="cart-footer" style="display:none">
      <div class="cart-total">
        <span class="label">合计</span>
        <span class="amount">¥<span id="cart-total">0</span></span>
      </div>
      <button class="btn-checkout" onclick="goCheckout()">去结算</button>
    </div>
  </aside>

  <!-- Main Content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="footer">
    <p>🥢 中华美食 · 在线点餐系统 © 2025</p>
    <p style="margin-top:4px;font-size:12px">美味不用等，一键送到家</p>
  </footer>

  <!-- Toast -->
  <div class="toast" id="toast"></div>

  <!-- Cart Logic -->
  <script is:inline>
    // Cart state
    let cart = JSON.parse(localStorage.getItem('cart') || '[]');

    function saveCart() {
      localStorage.setItem('cart', JSON.stringify(cart));
      updateCartUI();
    }

    function updateCartUI() {
      const countEl = document.getElementById('cart-count');
      const bodyEl = document.getElementById('cart-items');
      const emptyEl = document.getElementById('cart-empty');
      const footerEl = document.getElementById('cart-footer');
      const totalEl = document.getElementById('cart-total');

      const totalItems = cart.reduce((s, i) => s + i.quantity, 0);
      const totalPrice = cart.reduce((s, i) => s + i.price * i.quantity, 0);

      countEl.textContent = totalItems;

      if (cart.length === 0) {
        emptyEl.style.display = 'block';
        bodyEl.innerHTML = '';
        footerEl.style.display = 'none';
      } else {
        emptyEl.style.display = 'none';
        footerEl.style.display = 'block';
        totalEl.textContent = totalPrice.toFixed(0);

        bodyEl.innerHTML = cart.map((item, idx) => `
          <div class="cart-item">
            <div class="cart-item-info">
              <h4>${item.emoji} ${item.name}</h4>
              <div class="price">¥${item.price} × ${item.quantity} = ¥${item.price * item.quantity}</div>
            </div>
            <div class="qty-control">
              <button class="qty-btn" onclick="changeQty(${idx}, -1)">−</button>
              <span class="qty-num">${item.quantity}</span>
              <button class="qty-btn" onclick="changeQty(${idx}, 1)">+</button>
            </div>
          </div>
        `).join('');
      }

      // Update dish cards on menu page
      document.querySelectorAll('.dish-card').forEach(card => {
        const dishId = card.dataset.dishId;
        const inCart = cart.find(i => i.id === dishId);
        const addBtn = card.querySelector('.btn-add');
        const qtyCtrl = card.querySelector('.qty-control');
        const qtyNum = card.querySelector('.qty-num');
        if (addBtn && qtyCtrl) {
          if (inCart) {
            addBtn.style.display = 'none';
            qtyCtrl.style.display = 'flex';
            qtyNum.textContent = inCart.quantity;
          } else {
            addBtn.style.display = 'inline-block';
            qtyCtrl.style.display = 'none';
          }
        }
      });
    }

    function addToCart(id, name, price, emoji) {
      const existing = cart.find(i => i.id === id);
      if (existing) {
        existing.quantity++;
      } else {
        cart.push({ id, name, price, emoji, quantity: 1 });
      }
      saveCart();
      showToast(`${emoji} ${name} 已加入购物车`);
    }

    function changeQty(index, delta) {
      cart[index].quantity += delta;
      if (cart[index].quantity <= 0) {
        cart.splice(index, 1);
      }
      saveCart();
    }

    function toggleCart() {
      document.getElementById('cart-overlay').classList.toggle('open');
      document.getElementById('cart-sidebar').classList.toggle('open');
    }

    function goCheckout() {
      if (cart.length === 0) return;
      window.location.href = '/checkout';
    }

    function showToast(msg) {
      const el = document.getElementById('toast');
      el.textContent = msg;
      el.classList.add('show');
      setTimeout(() => el.classList.remove('show'), 2000);
    }

    // Init
    updateCartUI();
  </script>
</body>
</html>
